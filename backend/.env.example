# ── Core AI keys ──────────────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Shopify (kviyengars.myshopify.com) ────────────────────────────────────────
# Create a Custom App in Shopify Admin → Settings → Apps → Develop apps
# Grant: read_orders, write_orders
SHOPIFY_STORE_DOMAIN=kviyengars.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Set to "true" to use live Shopify data instead of the demo mock database
USE_SHOPIFY=false

# ── HubSpot CRM ───────────────────────────────────────────────────────────────
# Create a Private App in HubSpot → Settings → Integrations → Private Apps
# Scopes needed: crm.objects.contacts.write, crm.objects.tickets.write, crm.objects.notes.write
HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxxxxxxxxxxxxxx
